# ============================================================
# GitHub Trending Daily 环境变量配置
# 复制本文件为 .env 并填入实际值
# ============================================================

# ── 数据获取（可选）──
# GitHub Token（可选，提高 API 限额至 5000次/小时；无 token 时匿名调用 60次/小时）
# 获取地址：https://github.com/settings/tokens (Personal access tokens → Fine-grained)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# ── 邮件推送（订阅日报功能必填）──
# 发件邮箱地址（支持任意 SMTP 邮箱服务商）
QQ_EMAIL=your_email@example.com
# 邮箱授权码（在邮箱设置 → 账户 → POP3/SMTP 服务中开启并获取）
QQ_EMAIL_AUTH_CODE=xxxxxxxxxxxx
# 接收日报的邮箱（多个用逗号分隔）
RECEIVER_EMAIL=your_email@example.com

# ── LLM 深度分析（可选）──
# DeepSeek API Key（推荐，价格极低，每天分析 10 个项目约 0.01 元）
# 注册地址：https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx

# 其他厂商 LLM Key（可选，用于自定义日报的 LLM 解析）
# 用户在前端填入自己的 key 也可，这里配置的是服务端默认 key
# OpenAI_API_KEY=sk-xxxxxxxxxxxx
# Anthropic_API_KEY=sk-ant-xxxxxxxxxxxx
# Qwen_API_KEY=sk-xxxxxxxxxxxx
# Zhipu_API_KEY=xxxxxxxx.xxxxxxxx
# Moonshot_API_KEY=sk-xxxxxxxxxxxx

# ── Web 服务（可选，部署时使用）──
# Flask 调试模式（生产环境必须为 0）
FLASK_DEBUG=0
# 服务端口（HF Spaces 必须 7860；本地开发默认 5000）
PORT=5000
# 数据目录（HF Spaces 用 /data；本地默认 data）
DATA_DIR=data
