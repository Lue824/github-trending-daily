# GitHub Token（可选，提高 API 限额至 5000次/小时）
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# QQ 邮箱地址
QQ_EMAIL=your_qq@qq.com

# QQ 邮箱授权码（在 QQ邮箱设置 → 账户 → POP3/SMTP服务 中获取）
QQ_EMAIL_AUTH_CODE=xxxxxxxxxxxx

# 接收日报的邮箱
RECEIVER_EMAIL=your_qq@qq.com

# DeepSeek API Key（可选，启用 LLM 深度中文分析）
# 注册地址：https://platform.deepseek.com → API Keys
# 价格极低，每天分析 10 个项目约消耗 0.01 元
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx
